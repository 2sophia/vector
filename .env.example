# Sophia Vector — Environment Configuration
# Copia in .env e adatta i valori.

# ── Applicazione (prefisso SOPHIA_VECTOR_) ───────────────
SOPHIA_VECTOR_DEBUG=false
SOPHIA_VECTOR_BACKEND_PORT=8100
SOPHIA_VECTOR_FRONTEND_PORT=3100

# API key del backend (postura single-tenant). Vuota = nessun controllo: ok se la
# porta del backend è raggiungibile solo dal frontend / rete fidata. Valorizzala se
# esponi il backend: /v1/* richiederà "Authorization: Bearer <key>". Tieni BACKEND_API_KEY
# (sezione frontend) allineata allo stesso valore, così il proxy la inoltra.
SOPHIA_VECTOR_API_KEY=
SOPHIA_VECTOR_CORS_ORIGINS=

# Master key per cifrare i secret delle ingestion sources (SharePoint client_secret).
# IMPOSTALA in produzione. Vuota = chiave di sviluppo NON sicura.
SOPHIA_VECTOR_SECRET_KEY=

# ── MongoDB (URI completo con nome db) ───────────────────
SOPHIA_VECTOR_MONGODB_URI=mongodb://localhost:27017/sophia_vector

# ── Qdrant ───────────────────────────────────────────────
SOPHIA_VECTOR_QDRANT_URL=http://localhost:6333
SOPHIA_VECTOR_QDRANT_API_KEY=

# ── Docling (parser) ─────────────────────────────────────
SOPHIA_VECTOR_DOCLING_URL=http://localhost:5001
# Anti-leak: ogni N doc completati il worker svuota le cache di Docling (l'OCR
# trattiene i modelli → RAM che non scende). Default ON. 0 = disattivato.
SOPHIA_VECTOR_DOCLING_CLEAR_EVERY=20

# ── Embeddings + rerank (BGE-M3 service) ─────────────────
SOPHIA_VECTOR_EMBEDDINGS_URL=http://localhost:8004

# ── Storage / limiti ─────────────────────────────────────
SOPHIA_VECTOR_FILES_STORAGE=/app/storage/files
SOPHIA_VECTOR_DOCUMENTS_STORAGE=/app/storage/documents
SOPHIA_VECTOR_MAX_FILE_SIZE_MB=512

# ── Parser Docling (tuning, opzionale) ───────────────────
# document_timeout per-doc: tienilo sotto il massimo della tua istanza Docling.
SOPHIA_VECTOR_PARSER_MAX_WAIT_SECONDS=36000
SOPHIA_VECTOR_PARSER_MODEL_TOKENIZER=BAAI/bge-m3
# Chunk piccoli = retrieval più preciso (il contesto perso lo recupera il grafo :NEXT).
SOPHIA_VECTOR_PARSER_MODEL_MAX_TOKENS=512
# OCR on by default: PDF scansionati/immagini vengono letti (force_ocr resta off).
SOPHIA_VECTOR_PARSER_USE_OCR=true
SOPHIA_VECTOR_PARSER_PICTURE_DESCRIPTION=false
# "fast" e NON "accurate": accurate esplode su tabelle a celle larghe (griglie
# patologiche → milioni di token → ReadTimeout). Vedi docling issue #3428.
SOPHIA_VECTOR_PARSER_TABLE_MODE=fast
SOPHIA_VECTOR_PARSER_TABLE_CELL_MATCHING=false
SOPHIA_VECTOR_PARSER_PDF_BACKEND=docling_parse

# ── Knowledge graph FalkorDB (layer ADDITIVO su Qdrant) ──
# GRAPH_ENABLED=false disattiva del tutto la scrittura grafo (pipeline Qdrant
# invariata). La scrittura è best-effort: se FalkorDB è giù l'ingestion non fallisce.
SOPHIA_VECTOR_GRAPH_ENABLED=true
# PERSISTENZA: abilita l'AOF di FalkorDB o un restart del container AZZERA il grafo (con la
# config di default salva solo snapshot RDB periodici). Nel docker-compose, servizio falkordb:
#   environment: { REDIS_ARGS: "--appendonly yes --save 60 1000" }
# Qdrant non è interessato; il grafo è derivato → in caso di perdita si ricostruisce con un re-ingest.
SOPHIA_VECTOR_FALKOR_HOST=localhost
SOPHIA_VECTOR_FALKOR_PORT=6379
SOPHIA_VECTOR_FALKOR_PASSWORD=falkordb
# Namespace per i nomi grafo (più progetti su una FalkorDB). Vuoto = nome grafo = vector_store_id.
SOPHIA_VECTOR_FALKOR_GRAPH_PREFIX=

# ── Entity extraction (GLiNER zero-shot + regex, niente LLM) ──
# GLiNER è OFF di default: è pesante (~1.3GB) e zero-shot (rumoroso). Il GRAFO resta
# ON e popolato dalle REGEX ad alta precisione (email/URL/IBAN/ISIN/importi/date/
# riferimenti normativi + CF/P.IVA) → knowledge graph + viz out-of-the-box, leggero.
# Metti =true per le entità "soft" (autorità, organi, prodotti…). Default tarato banking.
SOPHIA_VECTOR_GLINER_ENABLED=false
SOPHIA_VECTOR_GLINER_MODEL=gliner-community/gliner_medium-v2.5
SOPHIA_VECTOR_GLINER_THRESHOLD=0.5
# Label di default (CSV, zero-shot, tarate banking/legal). Override per-scope da UI.
SOPHIA_VECTOR_GLINER_LABELS=autorità di vigilanza,organizzazione,persona,organo aziendale,normativa,prodotto finanziario,luogo,data,importo monetario
# Device GLiNER/relex/classifier: cpu | cuda | cuda:N | auto. Default cpu; "cuda"
# funziona solo sull'immagine CUDA (Dockerfile.cuda) — sull'immagine CPU ricade su cpu.
SOPHIA_VECTOR_GLINER_DEVICE=cpu

# ── Relation extraction (GLiNER-relex, archi TIPIZZATI; opt-in) ──
# Default OFF: 2° modello in RAM + ~0.2s/chunk. Abilitabile anche per-scope da UI.
SOPHIA_VECTOR_RELATIONS_ENABLED=false
SOPHIA_VECTOR_RELATIONS_MODEL=knowledgator/gliner-relex-multi-v1.0
SOPHIA_VECTOR_RELATIONS_ENTITY_THRESHOLD=0.5
SOPHIA_VECTOR_RELATIONS_THRESHOLD=0.45
SOPHIA_VECTOR_RELATIONS_ADJACENCY_THRESHOLD=0.55
# Label di relazione di default (CSV, zero-shot, da tarare sul dominio).
SOPHIA_VECTOR_RELATIONS_LABELS=pubblicato da,pubblicato il,emesso da,ai sensi di,modifica,sostituisce,fa riferimento a
# Filtri igiene agnostici: scarta estremi troppo lunghi (frasi) e relazioni other→other.
SOPHIA_VECTOR_RELATIONS_MAX_ENTITY_WORDS=8
SOPHIA_VECTOR_RELATIONS_DROP_OTHER_TO_OTHER=true

# ── Classificazione zero-shot dei chunk (GliClass; opt-in) ──
# Classifica i chunk su label arbitrarie (tipo-doc, tema, sensibilità) → tag in
# payload per faceting/filtri nella search. Predisposto e OFF: serve `pip install
# gliclass`. Best-effort (se la lib/modello mancano l'ingestion prosegue senza tag).
SOPHIA_VECTOR_CLASSIFIER_ENABLED=false
SOPHIA_VECTOR_CLASSIFIER_MODEL=knowledgator/gliclass-multilang-mini
SOPHIA_VECTOR_CLASSIFIER_THRESHOLD=0.5
SOPHIA_VECTOR_CLASSIFIER_MULTI_LABEL=true
# Label per TEMA + sensibilità (ortogonali), NON per tipo-documento (si sovrappongono).
SOPHIA_VECTOR_CLASSIFIER_LABELS=antiriciclaggio,privacy e protezione dati,governance societaria,gestione del credito,sicurezza informatica,vigilanza e compliance,dato personale

# ── Endpoint NLP (/v1/nlp/*): tokenize, detokenize, ner, classify, relex, transcribe ──
# Espongono i modelli già nel codebase come API. Il backend è "owner": li carica in-process
# (lazy, al primo hit) e li condivide con il worker, che li chiama via HTTP → una sola copia,
# sul device GLINER_DEVICE (Whisper su ASR_DEVICE). Vuoto/true = esposti.
SOPHIA_VECTOR_NLP_ENABLED=true

# ── MCP server (/mcp): Sophia Vector come server Model Context Protocol ──
# Espone search + i tool NLP (entità/classificazione/relazioni) agli agent compatibili MCP
# (Claude, sophia-agent, ecc.) riusando funzioni e modelli interni — nessun doppione. Protetto
# dalla stessa API key di /v1/* (Bearer). Trasporto streamable-HTTP su /mcp. Vuoto/true = attivo.
SOPHIA_VECTOR_MCP_ENABLED=true

# ── ASR (trascrizione audio/video, faster-whisper) ───────
# ASR_ENABLED=false → audio/video escono dalla whitelist (rifiutati a monte).
SOPHIA_VECTOR_ASR_ENABLED=true
SOPHIA_VECTOR_ASR_MODEL=small
SOPHIA_VECTOR_ASR_LANGUAGE=it
# Device Whisper: cpu | cuda | cuda:N | auto (vedi nota GLINER_DEVICE su immagine CUDA).
SOPHIA_VECTOR_ASR_DEVICE=cpu
SOPHIA_VECTOR_ASR_COMPUTE_TYPE=int8
SOPHIA_VECTOR_ASR_MAX_AUDIO_MINUTES=60
SOPHIA_VECTOR_ASR_MAX_VIDEO_MINUTES=30

# ── Data curation (dedup del CONTENUTO, soppressione boilerplate) ──
SOPHIA_VECTOR_CURATION_ENABLED=true
SOPHIA_VECTOR_CURATION_GRAPH_LINK=true
# Un chunk il cui body compare in oltre RATIO dei doc (e in almeno MIN_DOCS) = boilerplate.
SOPHIA_VECTOR_CURATION_BOILERPLATE_RATIO=0.5
SOPHIA_VECTOR_CURATION_BOILERPLATE_MIN_DOCS=5

# ── Ingestion worker (tuning, opzionale) ─────────────────
SOPHIA_VECTOR_INGEST_BATCH_SIZE=64
SOPHIA_VECTOR_INGEST_MAX_CONCURRENT_JOBS=1
SOPHIA_VECTOR_INGEST_WAIT_TIME_JOBS=3.0
SOPHIA_VECTOR_SHAREPOINT_POLL_INTERVAL=5.0

# ── Frontend Auth (Next.js server-side, NO prefisso SOPHIA_VECTOR_) ──
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3100
# Mongo per gli utenti NextAuth (può essere la stessa istanza del backend)
MONGODB_URI=mongodb://localhost:27017
AUTH_DB=sophia_vector
# URL backend per il proxy server-side del frontend
FASTAPI_URL=http://localhost:8100
# Se il backend ha SOPHIA_VECTOR_API_KEY impostata, mettila qui (stesso valore): il
# proxy la inoltra come Bearer. Vuota = nessuna API key inoltrata.
BACKEND_API_KEY=

# Primo login = admin automatico (credentials o Azure AD). Su un deploy
# pubblicamente raggiungibile, imposta BOOTSTRAP_ADMIN_EMAIL: solo quell'email può
# diventare l'admin iniziale (chiude la finestra di takeover). Vuoto = il primo
# utente in assoluto diventa admin (comodo in locale/dev).
BOOTSTRAP_ADMIN_EMAIL=

# ── Azure AD (login Microsoft, opzionale) ────────────────
# Lascia vuoto per disabilitare il login Microsoft.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# Allowlist domini email (csv). "*" disabilita il check (solo dev).
AZURE_AD_ALLOWED_DOMAINS=*

# ── SharePoint source di default (legacy, opzionale) ─────
# Usate solo se un job di ingestion non specifica un source_id.
# Preferire la creazione di sources via UI (credenziali cifrate).
AZURE_SITE_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
